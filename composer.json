{
    "name": "anketo/anketo",
    "description": "Customizable web form builder built with CodeIgniter 4, MySQL, and Bootstrap",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "codeigniter4/framework": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "phpunit/phpunit": "^10.0",
        "codeigniter4/devkit": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\Commands\\Utilities\\Requirements::postUpdate"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
