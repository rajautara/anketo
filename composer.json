{
    "name": "anketo/anketo",
    "description": "AnkeTo - Customizable drag & drop form builder built with CodeIgniter 4, MySQL, and Bootstrap",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/shield": "^1.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^10.5.16 || ^11.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\Commands\\Utilities\\Requirements::postUpdate"
        ],
        "test": "phpunit --no-coverage"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
